$ErrorActionPreference = "Stop"

$ServerRoot = "D:\Servers\Minecraft\Vanilla"
$ControlRoot = "D:\Servers\Control\minecraft-vanilla"
$JavaExe = "java"
$MinRam = "4G"
$MaxRam = "4G"
$JarName = "minecraft_server.26.1.2.jar"
$ServerPidFile = Join-Path $ControlRoot "minecraft.pid"
$WrapperPidFile = Join-Path $ControlRoot "wrapper.pid"
$StopFlag = Join-Path $ControlRoot "stop.flag"
$StdOutLog = Join-Path $ControlRoot "server.out.log"
$StdErrLog = Join-Path $ControlRoot "server.err.log"

if (-not (Test-Path $ServerRoot)) {
    throw "Server root not found: $ServerRoot"
}

New-Item -ItemType Directory -Path $ControlRoot -Force | Out-Null
Remove-Item $StopFlag -Force -ErrorAction SilentlyContinue

$psi = [System.Diagnostics.ProcessStartInfo]::new()
$psi.FileName = $JavaExe
$psi.WorkingDirectory = $ServerRoot
$psi.Arguments = "-Xms$MinRam -Xmx$MaxRam -jar $JarName nogui"
$psi.UseShellExecute = $false
$psi.RedirectStandardInput = $true
$psi.RedirectStandardOutput = $true
$psi.RedirectStandardError = $true
$psi.CreateNoWindow = $true

$process = [System.Diagnostics.Process]::new()
$process.StartInfo = $psi

$stdoutWriter = [System.IO.StreamWriter]::new($StdOutLog, $true)
$stderrWriter = [System.IO.StreamWriter]::new($StdErrLog, $true)

try {
    $null = $process.Start()
    Set-Content -Path $ServerPidFile -Value $process.Id
    Set-Content -Path $WrapperPidFile -Value $PID

    $process.BeginOutputReadLine()
    $process.BeginErrorReadLine()

    Register-ObjectEvent -InputObject $process -EventName OutputDataReceived -Action {
        if ($EventArgs.Data) {
            $Event.MessageData.StdOut.WriteLine($EventArgs.Data)
            $Event.MessageData.StdOut.Flush()
        }
    } -MessageData @{ StdOut = $stdoutWriter } | Out-Null

    Register-ObjectEvent -InputObject $process -EventName ErrorDataReceived -Action {
        if ($EventArgs.Data) {
            $Event.MessageData.StdErr.WriteLine($EventArgs.Data)
            $Event.MessageData.StdErr.Flush()
        }
    } -MessageData @{ StdErr = $stderrWriter } | Out-Null

    while (-not $process.HasExited) {
        if (Test-Path $StopFlag) {
            Remove-Item $StopFlag -Force -ErrorAction SilentlyContinue
            $process.StandardInput.WriteLine("stop")
            $process.StandardInput.Flush()

            if (-not $process.WaitForExit(120000)) {
                $process.Kill()
            }
            break
        }

        Start-Sleep -Seconds 2
    }
}
finally {
    $stdoutWriter.Dispose()
    $stderrWriter.Dispose()
    Unregister-Event -SourceIdentifier * -ErrorAction SilentlyContinue
    Remove-Item $ServerPidFile -Force -ErrorAction SilentlyContinue
    Remove-Item $WrapperPidFile -Force -ErrorAction SilentlyContinue
    Remove-Item $StopFlag -Force -ErrorAction SilentlyContinue
}
