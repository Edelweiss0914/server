#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="/opt/cheeze-control"
SRC_ROOT="/var/www/home/deploy/gateway"
SERVICE_FILE="/etc/systemd/system/cheeze-portal-api.service"

mkdir -p "$APP_ROOT"
cp "$SRC_ROOT/cheeze-portal-api.py" "$APP_ROOT/cheeze-portal-api.py"
chmod +x "$APP_ROOT/cheeze-portal-api.py"
cp "$SRC_ROOT/cheeze-portal-api.service.example" "$SERVICE_FILE"

systemctl daemon-reload
systemctl enable --now cheeze-portal-api
systemctl status cheeze-portal-api --no-pager
