#
# Tailscale-only admin surface for CHEEZE.
#
# Purpose:
# - keep the public homepage and /api/control user flows on the public domain
# - expose admin.html and /api/control/admin/* only on the gateway's Tailscale
#   IP or MagicDNS hostname
#
# Example access:
#   http://100.75.209.83/admin.html
#   http://gateway-lxc/admin.html
#
# Replace the listen/server_name directives to match your tailnet setup.
#

server {
    listen 80;
    listen [::]:80;

    # Prefer a specific tailnet name when available.
    server_name gateway-lxc 100.75.209.83;

    root /var/www/home;
    index admin.html;

    location = /admin.html {
        try_files /admin.html =404;
    }

    location /api/control/admin/ {
        proxy_pass http://127.0.0.1:11437/admin/;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header Connection "";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;

        proxy_connect_timeout 5s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
