# CHEEZE Docker Environment Variables
# Copy this file to .env and fill in actual values

# Cloudflare Tunnel token
CF_TUNNEL_TOKEN=

# Portal API — internal secret for Control API communication
CHEEZE_INTERNAL_SECRET=

# Portal API — legacy control token (optional, use token registry instead)
CHEEZE_PORTAL_CONTROL_TOKEN=

# Portal API — token registry and audit log paths (inside container)
CHEEZE_PORTAL_TOKEN_REGISTRY=/opt/cheeze-control/portal-control-tokens.json
CHEEZE_PORTAL_AUDIT_LOG=/opt/cheeze-control/portal-control-audit.log
CHEEZE_PORTAL_IP_LABELS=/opt/cheeze-control/portal-ip-labels.json

# Control API — backend agent address (Tailscale IP)
CHEEZE_BACKEND_BASE=http://100.86.252.21:5010

# Control API — WOL configuration
CHEEZE_WOL_MAC=<backend-mac-address>
CHEEZE_WOL_BROADCAST=192.168.50.255

# AI Queue — Ollama backend address
CHEEZE_AI_OLLAMA_BASE=http://100.86.252.21:11434
CHEEZE_AI_BACKEND_BASE=http://control-api:11436
